{
    "name": "czertainly-administrator",
    "version": "2.17.0",
    "homepage": ".",
    "private": true,
    "type": "module",
    "dependencies": {
        "@czertainly/openapi-types": "file:./src/types/openapi",
        "@floating-ui/dom": "^1.7.6",
        "@preline/input-number": "^4.1.3",
        "@preline/overlay": "^4.1.3",
        "@preline/select": "^4.1.3",
        "@preline/theme-switch": "^4.1.3",
        "@preline/toggle-password": "^4.1.3",
        "@preline/tooltip": "^4.1.3",
        "@reduxjs/toolkit": "^2.11.2",
        "@tailwindcss/vite": "^4.2.2",
        "apexcharts": "^5.10.1",
        "buffer": "^6.0.3",
        "classnames": "^2.5.1",
        "cron-expression-validator": "^1.0.20",
        "cron-parser": "^5.5.0",
        "cronstrue": "^3.14.0",
        "czertainly-administrator": "file:",
        "dagre": "^0.8.5",
        "dompurify": "^3.3.3",
        "highlight.js": "^11.11.1",
        "html-react-parser": "^6.0.1",
        "js-yaml": "^4.1.1",
        "jszip": "^3.10.1",
        "lodash.debounce": "^4.0.8",
        "lucide-react": "^1.7.0",
        "marked": "^18.0.0",
        "preline": "^4.1.3",
        "react": "^19.2.4",
        "react-apexcharts": "^2.1.0",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.72.1",
        "react-redux": "^9.2.0",
        "react-router": "^7.14.0",
        "react-simple-code-editor": "^0.14.1",
        "reactflow": "^11.11.4",
        "redux-observable": "^3.0.0-rc.3",
        "regexp-tree": "^0.1.27",
        "rxjs": "^7.8.2",
        "sass": "^1.99.0",
        "simplebar-react": "^3.3.2",
        "tailwindcss": "^4.2.2",
        "usehooks-ts": "^3.1.1",
        "web-vitals": "^5.2.0"
    },
    "scripts": {
        "start": "vite",
        "build": "vite build",
        "serve": "vite preview",
        "lint": "biome check .",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "test": "npm run test:all",
        "test:vitest": "vitest run",
        "test:vitest:ui": "vitest --ui",
        "test:vitest:watch": "vitest",
        "test:vitest:cov": "vitest run --coverage",
        "test:playwright": "playwright test -c playwright-ct.config.ts",
        "test:chromium": "playwright test -c playwright-ct.config.ts --project=chromium && node scripts/clean-lcov.js",
        "test:firefox": "playwright test -c playwright-ct.config.ts --project=firefox",
        "test:webkit": "playwright test -c playwright-ct.config.ts --project=webkit",
        "test:ui": "playwright test -c playwright-ct.config.ts --ui",
        "test:debug": "playwright test -c playwright-ct.config.ts --debug",
        "test:all": "npm run test:vitest && npm run test:playwright",
        "test:cov": "npm run test:vitest:cov && npm run test:chromium",
        "prepare": "husky",
        "generate-types": "openapi-generator-cli generate --generator-key typescript-rxjs-remote && biome format --write src/types/openapi",
        "generate-types-local": "openapi-generator-cli generate --generator-key typescript-rxjs-local && biome format --write src/types/openapi",
        "generate-types-utils": "openapi-generator-cli generate --generator-key typescript-rxjs-utils && biome format --write src/types/openapi/utils"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.13",
        "@openapitools/openapi-generator-cli": "^2.31.1",
        "@playwright/experimental-ct-react": "^1.59.1",
        "@playwright/test": "^1.59.1",
        "@tailwindcss/forms": "^0.5.11",
        "@types/dagre": "^0.7.54",
        "@types/js-yaml": "^4.0.9",
        "@types/lodash.debounce": "^4.0.9",
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react-swc": "^4.3.0",
        "@vitest/coverage-v8": "^4.1.3",
        "@vitest/ui": "^4.1.3",
        "babel-plugin-istanbul": "^8.0.0",
        "happy-dom": "^20.8.9",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "monocart-coverage-reports": "^2.12.9",
        "monocart-reporter": "^2.10.0",
        "nyc": "^18.0.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.7",
        "vite-plugin-istanbul": "^8.0.0",
        "vitest": "^4.1.3"
    },
    "overrides": {
        "typescript": "$typescript",
        "nodemailer": "^8.0.5"
    },
    "lint-staged": {
        "*.{ts,tsx,js,cjs,jsx,mjs,json}": [
            "biome check --write --no-errors-on-unmatched"
        ]
    }
}
