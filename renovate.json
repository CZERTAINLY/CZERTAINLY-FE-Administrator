{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:base", ":dependencyDashboard"],
    "schedule": ["before 6am on Monday"],
    "timezone": "Europe/Prague",
    "labels": ["dependencies"],
    "prConcurrentLimit": 10,
    "packageRules": [
        {
            "matchUpdateTypes": ["minor", "patch"],
            "groupName": "all non-major dependencies",
            "groupSlug": "all-minor-patch"
        },
        { "matchManagers": ["github-actions"], "groupName": "github actions", "groupSlug": "github-actions" },
        { "matchPackagePatterns": ["^@preline/", "^preline$"], "groupName": "preline" },
        { "matchPackagePatterns": ["^@tailwindcss/", "^tailwindcss$"], "groupName": "tailwind" },
        { "matchPackagePatterns": ["^@playwright/"], "groupName": "playwright" },
        { "matchPackagePatterns": ["^vitest$", "^@vitest/"], "groupName": "vitest" },
        { "matchPackagePatterns": ["^eslint", "^@typescript-eslint/"], "groupName": "eslint" },
        { "matchPackagePatterns": ["^vite$", "^@vitejs/", "^vite-plugin-"], "groupName": "vite" },
        { "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"], "groupName": "react" },
        { "matchPackageNames": ["@reduxjs/toolkit", "react-redux", "redux-observable"], "groupName": "redux" },
        { "matchPackagePatterns": ["^@types/"], "groupName": "types" },
        { "matchUpdateTypes": ["major"], "dependencyDashboardApproval": true }
    ],
    "lockFileMaintenance": { "enabled": true, "schedule": ["before 6am on Monday"] }
}
